# Demo mode — set to false to require Supabase auth
NEXT_PUBLIC_DEMO_MODE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI — required for all agents, content, research, leads, and outreach generation.
OPENAI_API_KEY=
# Optional model overrides (defaults shown)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_QUALITY=gpt-4o
CONTENTOPS_API_URL=http://localhost:3000

# Media generation — Kimi (images) & PixVerse (video)
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
PIXVERSE_API_KEY=
PIXVERSE_MODEL=v4.5

# Platform OAuth — required for real social connections (Dashboard → Integrations)
# Redirect URI for each platform: http://localhost:3000/api/integrations/{platform}/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Legacy single-token fallbacks (optional)
LINKEDIN_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
