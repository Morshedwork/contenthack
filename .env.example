# Demo mode — set to false to require Supabase auth
NEXT_PUBLIC_DEMO_MODE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Required on the server (Vercel) to persist campaigns, drafts, images, and agent output
SUPABASE_SERVICE_ROLE_KEY=

# AI — OpenAI powers text generation; Bright Data powers lead discovery; CrustData powers market/lead fallback; Kimi + OpenAI power images; PixVerse or OpenRouter power video.
OPENAI_API_KEY=
# Set true to hide OpenAI models and skip OpenAI routing (e.g. quota exhausted)
OPENAI_DISABLED=false
# OpenRouter — unified API for image + video models (Veo, Seedance, Sora, Seedream, Flux, GPT Image, etc.)
OPENROUTER_API_KEY=
# Open-source text models via OpenRouter (used when OpenAI is disabled/unavailable)
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v3.2
OPENROUTER_TEXT_MODELS=deepseek/deepseek-v3.2,meta-llama/llama-4-maverick,qwen/qwen3-235b-a22b-2507,meta-llama/llama-3.3-70b-instruct,qwen/qwen3-next-80b-a3b-instruct,mistralai/mistral-small-3.2-24b-instruct,google/gemma-3-27b-it,z-ai/glm-4.7-flash
# Bright Data — LinkedIn lead discovery with profile URLs (Deep Lookup + optional SERP)
BRIGHTDATA_API_KEY=
# Optional: SERP API zone name for faster LinkedIn profile search (Control Panel → SERP API)
# BRIGHTDATA_SERP_ZONE=
CRUSTDATA_API_KEY=
KIMI_API_KEY=
PIXVERSE_API_KEY=
# Voice — ElevenLabs TTS + Conversational Agents (Dashboard → Voice Manager)
ELEVENLABS_API_KEY=
# Optional: auto-provisioned on first "Start agent" if unset
# ELEVENLABS_AGENT_ID=
# Optional: specific voice + model (defaults: Rachel / eleven_turbo_v2_5)
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
# Japanese TTS + convai (29 langs on multilingual_v2; defaults to eleven_multilingual_v2)
# ELEVENLABS_MULTILINGUAL_MODEL=eleven_multilingual_v2
# Bangla TTS + convai (not on multilingual_v2; defaults to eleven_v3_conversational)
# ELEVENLABS_BENGALI_MODEL=eleven_v3_conversational
# Agent realtime voice model (English agents require turbo_v2 or flash_v2)
# ELEVENLABS_AGENT_MODEL=eleven_turbo_v2

# Email — Nodemailer + SMTP powers one-click outreach delivery (Dashboard → Outreach Studio)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true for port 465 (SSL); leave unset for STARTTLS on 587
# SMTP_SECURE=false
# Sender shown to recipients, e.g. "Your Name <you@yourdomain.com>"
# EMAIL_FROM=
# EMAIL_REPLY_TO=

# Optional model overrides (defaults shown; Model Hub routing takes precedence per task)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_QUALITY=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-2
KIMI_MODEL=kimi-k2.5
PIXVERSE_MODEL=v6
# Video — layered stack: OpenRouter models first (best → good), PixVerse last
VIDEO_LAYER=layered
# Budget-first video chain (OpenRouter has no $0 video models — these are cheapest paid)
OPENROUTER_VIDEO_MODEL=bytedance/seedance-1-5-pro
OPENROUTER_VIDEO_MODELS=bytedance/seedance-1-5-pro,bytedance/seedance-2.0-fast,alibaba/wan-2.6,google/veo-3.1-lite,kwaivgi/kling-v3.0-std,x-ai/grok-imagine-video,minimax/hailuo-2.3
OPENROUTER_VIDEO_RESOLUTION=720p
# OPENROUTER_VIDEO_GENERATE_AUDIO=false
PIXVERSE_VIDEO_MODELS=v6,v5.5,v5,v4.5
# OpenRouter image default (budget). True free images = Pollinations Flux in Image Studio.
OPENROUTER_IMAGE_MODEL=krea/krea-2-medium-turbo
OPENROUTER_IMAGE_MODELS=krea/krea-2-medium-turbo,google/gemini-3.1-flash-lite-image,black-forest-labs/flux.2-klein-4b,sourceful/riverflow-v2.5-fast,google/gemini-2.5-flash-image
# Force single provider: layered | openrouter | pixverse
# VIDEO_LAYER=openrouter

# TRAE MCP — stdio bridge in `.trae/mcp.json` (local) or `.trae/mcp.production.example.json` (deployed API)
CONTENTOPS_API_URL=http://localhost:3000
# Production: set the same secret on Vercel and in TRAE MCP env (recommended)
# CONTENTOPS_MCP_SECRET=
# Optional fallback: allow MCP without a secret (not recommended on public deployments)
# CONTENTOPS_MCP_ALLOW_ANONYMOUS=true

# Platform OAuth — required for real social connections (Dashboard → Integrations)
# Redirect URI for each platform: http://localhost:3000/api/integrations/{platform}/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Legacy single-token fallbacks (optional)
LINKEDIN_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
